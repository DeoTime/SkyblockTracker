# Copy to .env.local and adjust.

# When true the app serves deterministic fake data and never touches the network.
# The default is ON: the check is `!== 'false'`, so an unset variable means
# mocks. That is why a fresh production build shows demo data until the two
# variables below are set as BUILD variables — see the note at the bottom.
VITE_USE_MOCKS=true

# Base URL for the backend REST API. With the default Vite proxy, "/api" is
# forwarded to VITE_API_PROXY_TARGET, so locally you rarely change this.
# In production it must be the API's absolute public URL.
VITE_API_BASE_URL=/api

# Where the dev-server proxy forwards /api requests. The read API is bound to
# the Chicago host's loopback, so open a tunnel first:
#   ssh -L 4000:127.0.0.1:4000 nerfchess
VITE_API_PROXY_TARGET=http://localhost:4000

# ---------------------------------------------------------------------------
# Production
#
# Vite substitutes VITE_* into the bundle at BUILD time. Setting these under
# Workers -> Settings -> Variables & Secrets does nothing: they are not read at
# runtime, and a static-assets Worker has no script to read them anyway.
#
# Set them under Workers Builds -> build configuration -> Build variables, then
# trigger a rebuild:
#
#   VITE_USE_MOCKS=false
#   VITE_API_BASE_URL=https://api.wwolf.shop/api
#
# The API must be publicly reachable first (api/tunnel.sh) — Cloudflare's edge
# cannot see the Chicago host's loopback, and an unreachable API renders
# "Could not load" rather than falling back to mocks.

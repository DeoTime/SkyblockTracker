# Copy to .env.local and adjust.

# When true the app serves deterministic fake data and never touches the network.
# Leave this on until the backend from BACKEND.md is running.
VITE_USE_MOCKS=true

# Base URL for the backend REST API. With the default Vite proxy, "/api" is
# forwarded to VITE_API_PROXY_TARGET, so you rarely need to change this.
VITE_API_BASE_URL=/api

# Where the dev-server proxy forwards /api requests.
VITE_API_PROXY_TARGET=http://localhost:4000
